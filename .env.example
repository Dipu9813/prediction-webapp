# ----------------------------------------------------------------------------
# Supabase project credentials.
# Get these from: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------------------------

# Public — safe to expose to the browser. Used by the app for all normal queries
# (Row-Level Security enforces who can read/write what).
NEXT_PUBLIC_SUPABASE_URL="https://<your-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-public-key>"

# Site URL — used for OAuth redirect callbacks.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Real match data (server-only — NEVER expose these to the browser)
# ----------------------------------------------------------------------------

# Service role key — Supabase Dashboard > Project Settings > API > service_role.
# Lets the /api/sync job write fixtures into `matches` (bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# football-data.org API token — free signup at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY="<your-football-data-token>"

# Which competition + season to pull. WC = FIFA World Cup. Season is the year.
FOOTBALL_COMPETITION="WC"
FOOTBALL_SEASON="2026"

# Shared secret protecting the /api/sync endpoint when called by the Vercel cron.
# Generate one: openssl rand -hex 16
CRON_SECRET="<random-secret>"
